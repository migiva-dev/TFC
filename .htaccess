# =====================================================
# ARCHIVO: .htaccess
# PROYECTO: TFC - Configuración de Seguridad y SSL
# =====================================================

# -------------------------------------------------------
# 1. MOTOR DE REESCRITURA Y REDIRECCIÓN HTTPS
# -------------------------------------------------------
RewriteEngine On

# Forzar HTTPS: Redirige cualquier petición HTTP a HTTPS automáticamente
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# -------------------------------------------------------
# 2. CABECERAS DE SEGURIDAD (HTTP Headers)
# -------------------------------------------------------
<IfModule mod_headers.c>
    # Anti-Clickjacking: Evita que la web se cargue en iframes externos
    Header always set X-Frame-Options "SAMEORIGIN"

    # Anti-Sniffing: Evita que el navegador ignore el tipo de contenido definido
    Header always set X-Content-Type-Options "nosniff"

    # Filtro XSS: Bloquea ataques de scripts entre sitios en navegadores antiguos
    Header always set X-XSS-Protection "1; mode=block"

    # HSTS: Obliga al navegador a usar siempre HTTPS (opcional, actívalo tras probar)
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# -------------------------------------------------------
# 3. RESTRICCIÓN DE ACCESO A ARCHIVOS SENSIBLES
# -------------------------------------------------------

# Evitamos que se listen los archivos de las carpetas (Directory Browsing)
Options -Indexes

# Bloquear acceso a archivos de configuración y núcleo (PHP)
<FilesMatch "^(config|db|funciones|header|footer)\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>

# Bloquear archivos ocultos (como el propio .htaccess o .gitignore)
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>

# -------------------------------------------------------
# 4. GESTIÓN DE ERRORES
# -------------------------------------------------------

# Si hay un error 404, redirigimos a la página principal del proyecto
ErrorDocument 404 /public/index.php